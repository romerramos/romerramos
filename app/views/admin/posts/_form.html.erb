<%= form_with model: [:admin, post], class: "contents" do |form| %>
  <% if post.errors.any? %>
    <div class="rounded-lg border border-red-500/30 bg-red-500/10 p-4 mb-6">
      <p class="text-red-400 font-medium mb-2"><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</p>
      <ul class="list-disc list-inside text-red-400/80 text-sm space-y-1">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title, class: "block text-sm font-medium text-white/80 mb-1" %>
    <%= form.text_field :title, required: true, placeholder: "Post title", class: "block rounded-md border border-white/20 bg-white/5 focus:border-brand focus:ring-1 focus:ring-brand px-3 py-2.5 mt-1 w-full placeholder-white/40 text-white" %>
  </div>

  <div class="my-5">
    <%= form.label :description, class: "block text-sm font-medium text-white/80 mb-1" %>
    <%= form.text_field :description, required: true, placeholder: "A short tweet-size preview of the content", class: "block rounded-md border border-white/20 bg-white/5 focus:border-brand focus:ring-1 focus:ring-brand px-3 py-2.5 mt-1 w-full placeholder-white/40 text-white" %>
    <p class="text-xs text-white/40 mt-1">Keep it concise — this is the preview shown in listings.</p>
  </div>

  <div class="my-5">
    <%= form.label :published_at, "Published at", class: "block text-sm font-medium text-white/80 mb-1" %>
    <%= form.datetime_local_field :published_at, class: "block rounded-md border border-white/20 bg-white/5 focus:border-brand focus:ring-1 focus:ring-brand px-3 py-2.5 mt-1 w-full text-white" %>
    <p class="text-xs text-white/40 mt-1">Leave blank for a draft, or set a date in the past or future.</p>
  </div>

  <div class="my-5">
    <%= form.label :content, class: "block text-sm font-medium text-white/80 mb-1" %>
    <div class="dark">
      <%= form.marksmith :content, placeholder: "Write your markdown content here..." %>
    </div>
  </div>

  <div class="flex items-center gap-4 mt-8">
    <%= form.submit class: "rounded-md px-5 py-2.5 bg-brand hover:bg-brand/90 text-white inline-block font-medium cursor-pointer" %>
    <%= link_to "Cancel", admin_posts_path, class: "text-sm font-medium text-white/60 hover:text-white transition-colors" %>
  </div>
<% end %>
