<div class="w-full max-w-3xl">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-500/20 mb-5 text-red-400 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-3xl md:text-4xl mb-8">New Post</h1>

  <%= render "form", post: @post %>
</div>
