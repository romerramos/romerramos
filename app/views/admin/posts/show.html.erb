<div class="w-full max-w-4xl">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-brand/20 mb-5 text-brand font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex items-center justify-between mb-6">
    <h1 class="font-bold text-3xl md:text-4xl"><%= @post.title %></h1>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_post_path(@post), class: "rounded-md px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-medium transition-colors cursor-pointer" %>
      <%= button_to "Delete", admin_post_path(@post), method: :delete, class: "rounded-md px-4 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 text-sm font-medium transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to delete this post?" } %>
    </div>
  </div>

  <div class="mb-6">
    <p class="text-white/70 text-lg"><%= @post.description %></p>
    <div class="flex items-center gap-3 mt-3 text-sm text-white/40">
      <% if @post.published_at %>
        <span>Published <%= l @post.published_at, format: :long %></span>
      <% else %>
        <span>Draft</span>
      <% end %>
      <span>&middot;</span>
      <span>Created <%= l @post.created_at, format: :long %></span>
    </div>
  </div>

  <div class="border-t border-white/10 pt-6">
    <div class="text-white/90 leading-relaxed">
      <%== sanitize(marksmithed(@post.content), tags: %w(table th tr td span) + ActionView::Helpers::SanitizeHelper.sanitizer_vendor.safe_list_sanitizer.allowed_tags.to_a) %>
    </div>
  </div>

  <div class="mt-10">
    <%= link_to "&larr; Back to Jot Spot".html_safe, admin_posts_path, class: "text-sm font-medium text-white/60 hover:text-brand transition-colors" %>
  </div>
</div>
