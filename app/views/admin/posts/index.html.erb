<div class="w-full max-w-4xl">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-brand/20 mb-5 text-brand font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex items-center justify-between mb-8">
    <h1 class="font-bold text-3xl md:text-4xl">Jot Spot</h1>
    <%= link_to "New Post", new_admin_post_path, class: "rounded-md px-5 py-2.5 bg-brand hover:bg-brand/90 text-white inline-block font-medium cursor-pointer text-sm" %>
  </div>

  <% if @posts.any? %>
    <div class="space-y-4">
      <% @posts.each do |post| %>
        <div class="rounded-lg border border-white/10 bg-white/5 p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <h2 class="font-semibold text-lg text-white truncate"><%= post.title %></h2>
              <p class="text-sm text-white/60 mt-1 truncate"><%= post.description %></p>
              <div class="flex items-center gap-3 mt-3 text-xs text-white/40">
                <% if post.published_at %>
                  <span>Published <%= l post.published_at, format: :short %></span>
                <% else %>
                  <span>Draft</span>
                <% end %>
                <span>&middot;</span>
                <span>Created <%= l post.created_at, format: :short %></span>
              </div>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <%= link_to "View", admin_post_path(post), class: "text-sm font-medium text-white/70 hover:text-brand transition-colors" %>
              <%= link_to "Edit", edit_admin_post_path(post), class: "text-sm font-medium text-white/70 hover:text-brand transition-colors" %>
              <%= button_to "Delete", admin_post_path(post), method: :delete, class: "text-sm font-medium text-red-400 hover:text-red-300 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to delete this post?" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 border border-white/10 rounded-lg bg-white/5">
      <p class="text-white/60 mb-4">No posts yet.</p>
      <%= link_to "Create your first post", new_admin_post_path, class: "rounded-md px-5 py-2.5 bg-brand hover:bg-brand/90 text-white inline-block font-medium cursor-pointer text-sm" %>
    </div>
  <% end %>
</div>
