<div class="container mx-auto px-6 md:px-0 my-10 md:my-20">
  <div class="flex flex-col md:flex-row gap-8 md:gap-16">
    <div class="flex flex-col items-center md:items-start md:w-64 shrink-0">
      <div
        class="
          h-40 w-40 md:h-72 md:w-72 rounded-full border-[3px] border-brand overflow-hidden
        "
      >
        <%= image_tag "me_bio.jpg",
        class: "h-full w-full object-cover",
        style: "object-position: 15% center;" %>
      </div>

      <div class="mt-4">
        <%= render "shared/contact_links" %>
      </div>
    </div>

    <div class="flex-1 max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-bold mb-4">
        <span class="text-brand">Romer</span>
        Ramos
      </h1>

      <p class="text-xl md:text-2xl font-light mb-8">
        <%= t("about.subtitle_html") %>
      </p>

      <div class="space-y-6 text-base md:text-lg font-light leading-relaxed">
        <p><%= t("about.intro_html") %></p>
        <p><%= t("about.geeks_html") %></p>
        <p><%= t("about.academia_html") %></p>
        <p><%= t("about.spain_html") %></p>
        <p><%= t("about.aurora_html") %></p>
        <p><%= t("about.drawing_html") %></p>
        <p><%= t("about.lowfoot_html") %></p>
        <p><%= t("about.mypotential_html") %></p>
        <p><%= t("about.outro_html") %></p>
        <p><%= t("about.coffee_html") %></p>
      </div>
    </div>
  </div>
</div>
