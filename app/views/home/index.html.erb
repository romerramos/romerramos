<div class="container mx-auto flex justify-center px-6 md:px-0 my-10 md:my-20">
  <div class="w-full md:w-3xl">
    <div
      class="
        h-14 w-14 md:h-20 md:w-20 rounded-full border-[3px] border-brand overflow-hidden
      "
    >
      <%= image_tag "me.jpg", class: "h-full w-full object-cover grayscale" %>
    </div>

    <h1 class="my-4 text-4xl md:text-7xl font-bold ">
      <%= t("home.hello") %>
      <span class="text-brand"><%= t("home.name") %></span>!
    </h1>
    <p class="text-2xl md:text-3xl leading-snug md:leading-normal font-extralight">
      <%= t("home.bio_html") %>
    </p>
    <%= render "shared/contact_links" %>
  </div>
</div>
<div
  class="
    container mx-auto text-center text-white/20 font-semibold text-xs md:text-2xl
    my-10
  "
>
  Ruby on Rails . SvelteKit . Typescript . Go . Python . Java . TailwindCSS .
  Kubernetes . AWS . Photography . Specialty Coffee . Pencil Drawing . Games
</div>
