<div class="container mx-auto flex justify-center px-6 md:px-0 my-10 md:my-20">
  <div class="w-full md:w-3xl">
    <div
      class="
        h-14 w-14 md:h-20 md:w-20 rounded-full border-[3px] border-brand
        overflow-hidden
      "
    >
      <%= image_tag "me.jpg", class: "h-full w-full object-cover grayscale" %>
    </div>

    <h1 class="my-4 text-4xl md:text-7xl font-bold ">
      <%= t("home.hello") %>
      <span class="text-brand"><%= t("home.name") %></span>!
    </h1>
    <p class="text-2xl md:text-3xl leading-snug md:leading-normal font-extralight">
      <%= t("home.bio_html") %>
    </p>
    <ul class="font-extralight md:text-lg flex gap-2 my-6">
      <li>
        <a
          class="flex gap-1 items-center hover:text-brand"
          href="https://github.com/romerramos"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fa-brands fa-github text-base"></i><%= t("home.github") %>
        </a>
      </li>
      <li>
        <a
          class="flex gap-1 items-center hover:text-brand"
          href="https://linkedin.com/in/romerramos"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fa-brands fa-linkedin text-base"></i><%= t("home.linkedin") %>
        </a>
      </li>
      <li>
        <a
          class="flex gap-1 items-center hover:text-brand"
          href="mailto:romerramos@gmail.com"
        >
          <i class="fa-solid fa-at text-base"></i><%= t("home.email") %>
        </a>
      </li>
      <li>
        <a class="flex gap-1 items-center hover:text-brand" href="tel:+34722781489">
          <i class="fa-solid fa-phone text-base"></i><%= t("home.phone") %>
        </a>
      </li>
    </ul>
  </div>
</div>
